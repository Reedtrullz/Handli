{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handle.reidar.tech/schemas/benchmark-basket-candidate.v1.schema.json",
  "title": "Handleplan benchmark basket candidate evidence v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "contractVersion",
    "kind",
    "candidate",
    "bindings",
    "execution",
    "storeEvidence",
    "priceEvidence",
    "availabilityEvidence",
    "matchEvidence",
    "manualReconciliations",
    "runs"
  ],
  "properties": {
    "$schema": { "const": "./benchmark-basket-candidate.v1.schema.json" },
    "contractVersion": { "const": "2.0.0" },
    "kind": { "const": "handleplan-benchmark-basket-candidate" },
    "candidate": { "$ref": "#/$defs/candidate" },
    "bindings": { "$ref": "#/$defs/bindings" },
    "execution": { "$ref": "#/$defs/execution" },
    "storeEvidence": {
      "type": "array",
      "maxItems": 180,
      "items": { "$ref": "#/$defs/storeEvidence" }
    },
    "priceEvidence": {
      "type": "array",
      "maxItems": 1024,
      "items": { "$ref": "#/$defs/priceEvidence" }
    },
    "availabilityEvidence": {
      "type": "array",
      "maxItems": 180,
      "items": { "$ref": "#/$defs/availabilityEvidence" }
    },
    "matchEvidence": {
      "type": "array",
      "maxItems": 1024,
      "items": { "$ref": "#/$defs/matchEvidence" }
    },
    "manualReconciliations": {
      "type": "array",
      "maxItems": 60,
      "items": { "$ref": "#/$defs/manualReconciliation" }
    },
    "runs": {
      "type": "array",
      "minItems": 60,
      "maxItems": 60,
      "items": { "$ref": "#/$defs/run" }
    }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "pattern": "^[a-z0-9]+(?:[._:-][a-z0-9]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "regionId": {
      "type": "string",
      "pattern": "^no-[0-9]{4}-[a-z0-9-]+$"
    },
    "chainId": {
      "enum": ["bunnpris", "extra", "rema-1000"]
    },
    "priceClass": {
      "enum": ["official_offer", "ordinary"]
    },
    "priceEvidenceClass": {
      "enum": ["historical", "official_offer", "ordinary"]
    },
    "baseUnit": {
      "enum": ["g", "ml", "piece", "package"]
    },
    "positiveSafeInteger": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9007199254740991
    },
    "nonNegativeSafeInteger": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "commitSha", "imageDigest"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^candidate:sha256:[a-f0-9]{64}$"
        },
        "commitSha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "imageDigest": { "$ref": "#/$defs/sha256" }
      }
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "corpusVersion",
        "corpusDigest",
        "sourceRegistryVersion",
        "sourceRegistryDigest",
        "launchCoverageVersion",
        "launchCoverageDigest"
      ],
      "properties": {
        "corpusVersion": { "const": "1.0.0" },
        "corpusDigest": { "$ref": "#/$defs/sha256" },
        "sourceRegistryVersion": { "const": "1.0.0" },
        "sourceRegistryDigest": { "$ref": "#/$defs/sha256" },
        "launchCoverageVersion": { "const": "1.0.0" },
        "launchCoverageDigest": { "$ref": "#/$defs/sha256" }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["environmentId", "measuredAt", "enabledSourceIds"],
      "properties": {
        "environmentId": { "$ref": "#/$defs/identifier" },
        "measuredAt": { "$ref": "#/$defs/timestamp" },
        "enabledSourceIds": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        }
      }
    },
    "priceEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourceId",
        "sourceRecordId",
        "sourceRecordDigest",
        "chainId",
        "geographicScope",
        "canonicalProductId",
        "priceClass",
        "amountOre",
        "packageBaseUnits",
        "unit",
        "observedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^price-evidence:sha256:[a-f0-9]{64}$"
        },
        "sourceId": { "$ref": "#/$defs/identifier" },
        "sourceRecordId": { "$ref": "#/$defs/identifier" },
        "sourceRecordDigest": { "$ref": "#/$defs/sha256" },
        "chainId": { "$ref": "#/$defs/chainId" },
        "geographicScope": { "$ref": "#/$defs/geographicScope" },
        "canonicalProductId": { "$ref": "#/$defs/identifier" },
        "priceClass": { "$ref": "#/$defs/priceEvidenceClass" },
        "amountOre": { "$ref": "#/$defs/positiveSafeInteger" },
        "packageBaseUnits": { "$ref": "#/$defs/positiveSafeInteger" },
        "unit": { "$ref": "#/$defs/baseUnit" },
        "packageKind": { "enum": ["fixed", "variable-weight"] },
        "depositPerPackageOre": { "$ref": "#/$defs/nonNegativeSafeInteger" },
        "offerTerms": { "$ref": "#/$defs/offerTerms" },
        "observedAt": { "$ref": "#/$defs/timestamp" },
        "validFrom": { "$ref": "#/$defs/timestamp" },
        "validUntil": { "$ref": "#/$defs/timestamp" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "priceClass": { "const": "official_offer" } },
            "required": ["priceClass"]
          },
          "then": {
            "properties": {
              "offerTerms": { "$ref": "#/$defs/offerTerms" },
              "validFrom": { "$ref": "#/$defs/timestamp" },
              "validUntil": { "$ref": "#/$defs/timestamp" }
            },
            "required": ["offerTerms", "validFrom", "validUntil"]
          },
          "else": {
            "properties": { "offerTerms": false }
          }
        }
      ]
    },
    "offerTerms": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundleSize", "minimumPackages", "membershipRequirement"],
      "properties": {
        "bundleSize": { "$ref": "#/$defs/positiveSafeInteger" },
        "minimumPackages": { "$ref": "#/$defs/positiveSafeInteger" },
        "membershipRequirement": { "enum": ["none", "required"] },
        "membershipProgramId": { "$ref": "#/$defs/identifier" }
      },
      "allOf": [
        {
          "if": {
            "properties": { "membershipRequirement": { "const": "required" } },
            "required": ["membershipRequirement"]
          },
          "then": {
            "properties": { "membershipProgramId": { "$ref": "#/$defs/identifier" } },
            "required": ["membershipProgramId"]
          },
          "else": { "properties": { "membershipProgramId": false } }
        }
      ]
    },
    "storeEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourceId",
        "sourceRecordId",
        "sourceRecordDigest",
        "regionId",
        "chainId",
        "storeId",
        "observedAt",
        "validUntil"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^store-evidence:sha256:[a-f0-9]{64}$"
        },
        "sourceId": { "$ref": "#/$defs/identifier" },
        "sourceRecordId": { "$ref": "#/$defs/identifier" },
        "sourceRecordDigest": { "$ref": "#/$defs/sha256" },
        "regionId": { "$ref": "#/$defs/regionId" },
        "chainId": { "$ref": "#/$defs/chainId" },
        "storeId": { "$ref": "#/$defs/identifier" },
        "observedAt": { "$ref": "#/$defs/timestamp" },
        "validFrom": { "$ref": "#/$defs/timestamp" },
        "validUntil": { "$ref": "#/$defs/timestamp" }
      }
    },
    "availabilityEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "sourceId",
        "sourceRecordId",
        "sourceRecordDigest",
        "regionId",
        "chainId",
        "storeId",
        "canonicalProductId",
        "state",
        "observedAt",
        "validUntil"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^availability-evidence:sha256:[a-f0-9]{64}$"
        },
        "sourceId": { "$ref": "#/$defs/identifier" },
        "sourceRecordId": { "$ref": "#/$defs/identifier" },
        "sourceRecordDigest": { "$ref": "#/$defs/sha256" },
        "regionId": { "$ref": "#/$defs/regionId" },
        "chainId": { "$ref": "#/$defs/chainId" },
        "storeId": { "$ref": "#/$defs/identifier" },
        "canonicalProductId": { "$ref": "#/$defs/identifier" },
        "state": { "const": "known-not-carried" },
        "observedAt": { "$ref": "#/$defs/timestamp" },
        "validFrom": { "$ref": "#/$defs/timestamp" },
        "validUntil": { "$ref": "#/$defs/timestamp" }
      }
    },
    "geographicScope": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "countryCode"],
          "properties": {
            "kind": { "const": "national" },
            "countryCode": { "const": "NO" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "regionId"],
          "properties": {
            "kind": { "const": "region" },
            "regionId": { "$ref": "#/$defs/regionId" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "regionId", "storeId"],
          "properties": {
            "kind": { "const": "store" },
            "regionId": { "$ref": "#/$defs/regionId" },
            "storeId": { "$ref": "#/$defs/identifier" }
          }
        }
      ]
    },
    "matchEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "runId",
        "needId",
        "canonicalProductId",
        "method",
        "reviewedAt",
        "reviewerId",
        "familyId",
        "candidateSetDigest",
        "declaredConstraints",
        "unit"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^match-evidence:sha256:[a-f0-9]{64}$"
        },
        "runId": { "$ref": "#/$defs/identifier" },
        "needId": { "$ref": "#/$defs/identifier" },
        "canonicalProductId": { "$ref": "#/$defs/identifier" },
        "method": { "const": "reviewed-candidate" },
        "reviewedAt": { "$ref": "#/$defs/timestamp" },
        "reviewerId": { "$ref": "#/$defs/identifier" },
        "familyId": { "$ref": "#/$defs/identifier" },
        "candidateSetDigest": { "$ref": "#/$defs/sha256" },
        "declaredConstraints": {
          "type": "array",
          "maxItems": 16,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/identifier" }
        },
        "unit": { "$ref": "#/$defs/baseUnit" }
      }
    },
    "manualReconciliation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "runId",
        "reviewedAt",
        "reviewerId",
        "storeEvidenceIds",
        "priceEvidenceIds",
        "reviewedEvidenceDigest"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^reconciliation:sha256:[a-f0-9]{64}$"
        },
        "runId": { "$ref": "#/$defs/identifier" },
        "reviewedAt": { "$ref": "#/$defs/timestamp" },
        "reviewerId": { "$ref": "#/$defs/identifier" },
        "storeEvidenceIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^store-evidence:sha256:[a-f0-9]{64}$"
          }
        },
        "priceEvidenceIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 24,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^price-evidence:sha256:[a-f0-9]{64}$"
          }
        },
        "reviewedEvidenceDigest": { "$ref": "#/$defs/sha256" }
      }
    },
    "coverageEntry": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["chainId", "priceClass", "state", "sourceId"],
          "properties": {
            "chainId": { "$ref": "#/$defs/chainId" },
            "priceClass": { "$ref": "#/$defs/priceClass" },
            "state": { "const": "verified" },
            "sourceId": { "$ref": "#/$defs/identifier" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["chainId", "priceClass", "state"],
          "properties": {
            "chainId": { "$ref": "#/$defs/chainId" },
            "priceClass": { "$ref": "#/$defs/priceClass" },
            "state": { "const": "unresolved" }
          }
        }
      ]
    },
    "comparisonScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["qualification", "entries"],
      "properties": {
        "qualification": {
          "enum": ["declared-complete-coverage", "among-verified-prices"]
        },
        "entries": {
          "type": "array",
          "minItems": 6,
          "maxItems": 6,
          "items": { "$ref": "#/$defs/coverageEntry" }
        }
      }
    },
    "store": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storeId", "chainId", "regionId", "storeEvidenceId"],
      "properties": {
        "storeId": { "$ref": "#/$defs/identifier" },
        "chainId": { "$ref": "#/$defs/chainId" },
        "regionId": { "$ref": "#/$defs/regionId" },
        "storeEvidenceId": {
          "type": "string",
          "pattern": "^store-evidence:sha256:[a-f0-9]{64}$"
        }
      }
    },
    "assignment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "needId",
        "canonicalProductId",
        "storeId",
        "chainId",
        "packageCount",
        "packageBaseUnits",
        "purchasedBaseUnits",
        "unit",
        "ordinaryCostOre",
        "costOre",
        "priceEvidenceId",
        "appliedOfferEvidenceId",
        "matchEvidenceId"
      ],
      "properties": {
        "needId": { "$ref": "#/$defs/identifier" },
        "canonicalProductId": { "$ref": "#/$defs/identifier" },
        "storeId": { "$ref": "#/$defs/identifier" },
        "chainId": { "$ref": "#/$defs/chainId" },
        "packageCount": { "$ref": "#/$defs/positiveSafeInteger" },
        "packageBaseUnits": { "$ref": "#/$defs/positiveSafeInteger" },
        "purchasedBaseUnits": { "$ref": "#/$defs/positiveSafeInteger" },
        "unit": { "$ref": "#/$defs/baseUnit" },
        "ordinaryCostOre": { "$ref": "#/$defs/positiveSafeInteger" },
        "costOre": { "$ref": "#/$defs/positiveSafeInteger" },
        "priceEvidenceId": {
          "type": "string",
          "pattern": "^price-evidence:sha256:[a-f0-9]{64}$"
        },
        "appliedOfferEvidenceId": {
          "oneOf": [
            { "type": "null" },
            {
              "type": "string",
              "pattern": "^price-evidence:sha256:[a-f0-9]{64}$"
            }
          ]
        },
        "matchEvidenceId": {
          "type": "string",
          "pattern": "^match-evidence:sha256:[a-f0-9]{64}$"
        }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "stores", "assignments", "totalOre"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^plan:sha256:[a-f0-9]{64}$"
        },
        "stores": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": { "$ref": "#/$defs/store" }
        },
        "assignments": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": { "$ref": "#/$defs/assignment" }
        },
        "totalOre": { "$ref": "#/$defs/positiveSafeInteger" }
      }
    },
    "evaluatedRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runId",
        "regionId",
        "scenarioId",
        "state",
        "evaluatedAt",
        "comparisonScope",
        "plan"
      ],
      "properties": {
        "runId": { "$ref": "#/$defs/identifier" },
        "regionId": { "$ref": "#/$defs/regionId" },
        "scenarioId": { "$ref": "#/$defs/identifier" },
        "state": { "const": "evaluated" },
        "evaluatedAt": { "$ref": "#/$defs/timestamp" },
        "comparisonScope": { "$ref": "#/$defs/comparisonScope" },
        "plan": { "$ref": "#/$defs/plan" },
        "protocol": {
          "$ref": "https://handle.reidar.tech/schemas/benchmark-basket-protocol.v1.schema.json"
        }
      }
    },
    "pendingRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "regionId", "scenarioId", "state", "reason"],
      "properties": {
        "runId": { "$ref": "#/$defs/identifier" },
        "regionId": { "$ref": "#/$defs/regionId" },
        "scenarioId": { "$ref": "#/$defs/identifier" },
        "state": { "const": "pending" },
        "reason": {
          "enum": [
            "candidate-not-built",
            "manual-reconciliation-pending",
            "measurement-not-run",
            "rights-review-pending"
          ]
        }
      }
    },
    "blockedRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "regionId", "scenarioId", "state", "reason"],
      "properties": {
        "runId": { "$ref": "#/$defs/identifier" },
        "regionId": { "$ref": "#/$defs/regionId" },
        "scenarioId": { "$ref": "#/$defs/identifier" },
        "state": { "const": "blocked" },
        "reason": {
          "enum": [
            "coverage-not-eligible",
            "evidence-window-invalid",
            "no-eligible-live-evidence",
            "source-rights-unresolved",
            "source-suspended"
          ]
        }
      }
    },
    "failedRun": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runId", "regionId", "scenarioId", "state", "reason"],
      "properties": {
        "runId": { "$ref": "#/$defs/identifier" },
        "regionId": { "$ref": "#/$defs/regionId" },
        "scenarioId": { "$ref": "#/$defs/identifier" },
        "state": { "const": "failed" },
        "reason": {
          "enum": [
            "acceptance-assertion-failed",
            "planner-returned-no-complete-plan",
            "runner-error"
          ]
        }
      }
    },
    "run": {
      "oneOf": [
        { "$ref": "#/$defs/evaluatedRun" },
        { "$ref": "#/$defs/pendingRun" },
        { "$ref": "#/$defs/blockedRun" },
        { "$ref": "#/$defs/failedRun" }
      ]
    }
  }
}
