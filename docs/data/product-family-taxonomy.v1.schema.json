{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handle.reidar.tech/schemas/product-family-taxonomy.v1.schema.json",
  "title": "Handleplan reviewed product-family taxonomy v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "contractVersion",
    "taxonomyId",
    "taxonomyVersion",
    "versionId",
    "publishedAt",
    "contentSha256",
    "families"
  ],
  "properties": {
    "$schema": { "const": "./product-family-taxonomy.v1.schema.json" },
    "contractVersion": { "const": 1 },
    "taxonomyId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "taxonomyVersion": {
      "type": "string",
      "minLength": 5,
      "maxLength": 32,
      "pattern": "^(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"
    },
    "versionId": {
      "type": "string",
      "minLength": 7,
      "maxLength": 120,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*@(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)\\.(?:0|[1-9][0-9]*)$"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "contentSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "families": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": { "$ref": "#/$defs/family" }
    }
  },
  "$defs": {
    "familyId": {
      "type": "string",
      "minLength": 8,
      "maxLength": 80,
      "pattern": "^family:[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "slug": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "alias": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[a-z0-9æøå]+(?:[ -][a-z0-9æøå]+)*$"
    },
    "family": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slug", "labelNo", "aliases", "status"],
      "properties": {
        "id": { "$ref": "#/$defs/familyId" },
        "slug": { "$ref": "#/$defs/slug" },
        "labelNo": { "type": "string", "minLength": 1, "maxLength": 160 },
        "aliases": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/alias" }
        },
        "parentId": { "$ref": "#/$defs/familyId" },
        "status": { "enum": ["active", "retired"] }
      }
    }
  }
}
