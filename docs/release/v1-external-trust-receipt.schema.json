{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handle.reidar.tech/schemas/v1-external-trust-receipt.schema.json",
  "title": "Handleplan v1 external release trust receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["contractVersion", "statement", "signature"],
  "properties": {
    "contractVersion": { "const": "handleplan.external-release-trust.v1" },
    "statement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidateId",
        "sourceCommitSha",
        "candidateManifestSha256",
        "repository",
        "immutableReference",
        "manifestDigest",
        "verifiedAt",
        "expiresAt",
        "reviewer",
        "checks"
      ],
      "properties": {
        "candidateId": {
          "type": "string",
          "minLength": 3,
          "maxLength": 80,
          "pattern": "^[a-z0-9][a-z0-9.-]*$"
        },
        "sourceCommitSha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "candidateManifestSha256": { "$ref": "#/$defs/sha256" },
        "repository": {
          "type": "string",
          "minLength": 3,
          "maxLength": 200,
          "pattern": "^[a-z0-9.-]+(?::[1-9][0-9]{0,4})?/(?:[a-z0-9._-]+/)*[a-z0-9._-]+$"
        },
        "immutableReference": {
          "type": "string",
          "minLength": 75,
          "maxLength": 280
        },
        "manifestDigest": { "$ref": "#/$defs/ociDigest" },
        "verifiedAt": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "reviewer": { "type": "string", "minLength": 3, "maxLength": 160 },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": ["registryReadback", "imageSignature", "provenance", "gateEvidence"],
          "properties": {
            "registryReadback": { "const": "verified" },
            "imageSignature": { "$ref": "#/$defs/signerCheck" },
            "provenance": { "$ref": "#/$defs/signerCheck" },
            "gateEvidence": {
              "type": "object",
              "additionalProperties": false,
              "required": ["status", "gateIds"],
              "properties": {
                "status": { "const": "verified" },
                "gateIds": {
                  "type": "array",
                  "minItems": 12,
                  "maxItems": 12,
                  "uniqueItems": true,
                  "items": { "$ref": "#/$defs/gateId" }
                }
              }
            }
          }
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "keyId", "value"],
      "properties": {
        "algorithm": { "const": "ed25519" },
        "keyId": {
          "type": "string",
          "minLength": 3,
          "maxLength": 120,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
        },
        "value": {
          "type": "string",
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$"
        }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "ociDigest": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "gateId": {
      "enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10", "G11", "G12"]
    },
    "signerCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "signer"],
      "properties": {
        "status": { "const": "verified" },
        "signer": { "type": "string", "minLength": 3, "maxLength": 240 }
      }
    }
  }
}
