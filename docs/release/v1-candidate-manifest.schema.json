{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://handle.reidar.tech/schemas/v1-candidate-manifest.schema.json",
  "title": "Handleplan v1 release candidate evidence manifest",
  "$comment": "The promotion_candidate shape is reserved for future evidence architecture. The repository semantic verifier intentionally rejects every promotion_candidate today.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "manifestVersion",
    "candidateId",
    "mode",
    "createdAt",
    "releaseDecision",
    "source",
    "image",
    "database",
    "sourceRegistry",
    "coverageManifest",
    "evidence",
    "backup",
    "supportedRegions",
    "attestations",
    "gates",
    "missingOrUnverifiedGateIds",
    "limitations"
  ],
  "properties": {
    "$schema": { "const": "../../../release/v1-candidate-manifest.schema.json" },
    "manifestVersion": { "const": "1.0.0" },
    "candidateId": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80,
      "pattern": "^[a-z0-9][a-z0-9.-]*$"
    },
    "mode": {
      "description": "draft_unverified is supported. promotion_candidate is a reserved static shape that the semantic verifier always rejects.",
      "enum": ["draft_unverified", "promotion_candidate"]
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "releaseDecision": {
      "description": "eligible is reserved by the schema and is not an outcome the current verifier can return.",
      "enum": ["blocked", "eligible"]
    },
    "source": { "$ref": "#/$defs/source" },
    "image": { "$ref": "#/$defs/image" },
    "database": { "$ref": "#/$defs/database" },
    "sourceRegistry": { "$ref": "#/$defs/versionedFile" },
    "coverageManifest": { "$ref": "#/$defs/versionedFile" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ci", "tests", "scans", "reviews"],
      "properties": {
        "ci": { "$ref": "#/$defs/evidenceList" },
        "tests": { "$ref": "#/$defs/evidenceList" },
        "scans": { "$ref": "#/$defs/evidenceList" },
        "reviews": { "$ref": "#/$defs/evidenceList" }
      }
    },
    "backup": { "$ref": "#/$defs/backup" },
    "supportedRegions": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^no-[0-9]{4}-[a-z0-9]+(?:-[a-z0-9]+)*$"
      }
    },
    "attestations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sbom", "provenance", "imageSignature"],
      "properties": {
        "sbom": { "$ref": "#/$defs/attestedArtifact" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "imageSignature": { "$ref": "#/$defs/signature" }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 12,
      "maxItems": 12,
      "items": { "$ref": "#/$defs/gate" }
    },
    "missingOrUnverifiedGateIds": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/gateId" }
    },
    "limitations": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 500 }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "draft_unverified" } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "releaseDecision": { "const": "blocked" },
          "limitations": { "type": "array", "minItems": 1 },
          "missingOrUnverifiedGateIds": { "type": "array", "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "mode": { "const": "promotion_candidate" } },
        "required": ["mode"]
      },
      "then": {
        "properties": {
          "releaseDecision": { "const": "eligible" },
          "source": {
            "type": "object",
            "properties": {
              "treeState": { "const": "clean" },
              "commitBinding": { "const": "exact" }
            }
          },
          "image": {
            "type": "object",
            "properties": {
              "repository": { "type": "string" },
              "manifestDigest": { "type": "string" },
              "immutableReference": { "type": "string" },
              "registryReadbackEvidenceId": { "type": "string" },
              "promoted": { "const": true }
            }
          },
          "supportedRegions": { "type": "array", "minItems": 1 },
          "missingOrUnverifiedGateIds": { "type": "array", "maxItems": 0 },
          "limitations": { "type": "array", "maxItems": 0 }
        }
      }
    }
  ],
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "ociDigest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "relativePath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commitSha", "treeState", "commitBinding"],
      "properties": {
        "commitSha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "treeState": { "enum": ["clean", "dirty"] },
        "commitBinding": { "enum": ["exact", "baseline_only"] }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "repository",
        "manifestDigest",
        "digestKind",
        "immutableReference",
        "registryReadbackEvidenceId",
        "promoted"
      ],
      "properties": {
        "repository": { "type": ["string", "null"], "minLength": 1 },
        "manifestDigest": {
          "anyOf": [
            { "$ref": "#/$defs/ociDigest" },
            { "type": "null" }
          ]
        },
        "digestKind": { "const": "oci_manifest" },
        "immutableReference": { "type": ["string", "null"], "minLength": 1 },
        "registryReadbackEvidenceId": {
          "type": ["string", "null"],
          "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "promoted": { "type": "boolean" }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["startingState", "migrations"],
      "properties": {
        "startingState": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "identifier"],
          "properties": {
            "kind": {
              "enum": ["new_empty", "previous_release", "restored_backup", "unverified"]
            },
            "identifier": { "type": ["string", "null"], "minLength": 1 }
          }
        },
        "migrations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "sha256"],
            "properties": {
              "path": { "$ref": "#/$defs/relativePath" },
              "sha256": { "$ref": "#/$defs/sha256" }
            }
          }
        }
      }
    },
    "versionedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "version", "sha256"],
      "properties": {
        "path": { "$ref": "#/$defs/relativePath" },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "evidenceList": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "status",
        "command",
        "environment",
        "artifact",
        "sha256",
        "reviewedAt"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
        },
        "status": { "enum": ["passed", "failed", "unverified"] },
        "command": { "type": "string", "minLength": 1, "maxLength": 500 },
        "environment": { "type": "string", "minLength": 1, "maxLength": 300 },
        "artifact": {
          "anyOf": [
            { "$ref": "#/$defs/relativePath" },
            { "type": "null" }
          ]
        },
        "sha256": {
          "anyOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "reviewedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    },
    "backup": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "identifier",
        "createdAt",
        "restoreTestedAt",
        "artifact",
        "sha256"
      ],
      "properties": {
        "status": { "enum": ["missing", "unverified", "restore_verified"] },
        "identifier": { "type": ["string", "null"], "minLength": 1 },
        "createdAt": { "type": ["string", "null"], "format": "date-time" },
        "restoreTestedAt": { "type": ["string", "null"], "format": "date-time" },
        "artifact": {
          "anyOf": [
            { "$ref": "#/$defs/relativePath" },
            { "type": "null" }
          ]
        },
        "sha256": {
          "anyOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        }
      }
    },
    "attestedArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "subjectCommitSha", "artifact", "sha256"],
      "properties": {
        "status": { "enum": ["missing", "unverified", "verified"] },
        "subjectCommitSha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{40}$"
        },
        "artifact": {
          "anyOf": [
            { "$ref": "#/$defs/relativePath" },
            { "type": "null" }
          ]
        },
        "sha256": {
          "anyOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "subjectCommitSha",
        "subjectManifestDigest",
        "artifact",
        "sha256"
      ],
      "properties": {
        "status": {
          "enum": ["missing", "unsigned", "signed_unverified", "signed_verified"]
        },
        "subjectCommitSha": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{40}$"
        },
        "subjectManifestDigest": {
          "anyOf": [
            { "$ref": "#/$defs/ociDigest" },
            { "type": "null" }
          ]
        },
        "artifact": {
          "anyOf": [
            { "$ref": "#/$defs/relativePath" },
            { "type": "null" }
          ]
        },
        "sha256": {
          "anyOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "subjectManifestDigest",
        "artifact",
        "sha256",
        "signer",
        "verifiedAt"
      ],
      "properties": {
        "status": { "enum": ["missing", "unverified", "verified"] },
        "subjectManifestDigest": {
          "anyOf": [
            { "$ref": "#/$defs/ociDigest" },
            { "type": "null" }
          ]
        },
        "artifact": {
          "anyOf": [
            { "$ref": "#/$defs/relativePath" },
            { "type": "null" }
          ]
        },
        "sha256": {
          "anyOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "signer": { "type": ["string", "null"], "minLength": 1 },
        "verifiedAt": { "type": ["string", "null"], "format": "date-time" }
      }
    },
    "gateId": {
      "enum": ["G1", "G2", "G3", "G4", "G5", "G6", "G7", "G8", "G9", "G10", "G11", "G12"]
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "evidenceIds"],
      "properties": {
        "id": { "$ref": "#/$defs/gateId" },
        "status": { "enum": ["passed", "partial", "blocked", "not_started"] },
        "evidenceIds": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[.-][a-z0-9]+)*$"
          }
        }
      }
    }
  }
}
