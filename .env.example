KASSAL_API_KEY=
KASSAL_BASE_URL=https://kassal.app/api/v1
KASSAL_SOURCE_ACCESS=conditional
POSTGRES_PASSWORD=replace_with_url_safe_admin_secret
APP_DATABASE_PASSWORD=replace_with_url_safe_runtime_secret
WEB_DATABASE_PASSWORD=replace_with_distinct_url_safe_web_secret
REVIEW_DATABASE_PASSWORD=replace_with_distinct_url_safe_review_secret
OPERATIONS_DATABASE_PASSWORD=replace_with_distinct_url_safe_operations_secret
DATABASE_MIGRATION_URL=postgresql://handleplan:replace_with_url_safe_admin_secret@localhost:5432/handleplan
DATABASE_URL=postgresql://handleplan_web:replace_with_distinct_url_safe_web_secret@localhost:5432/handleplan
# Standalone/local review runtime only. Production Compose derives this URL from
# REVIEW_DATABASE_PASSWORD and injects it into the review process, never app.
REVIEW_DATABASE_URL=postgresql://handleplan_review:replace_with_distinct_url_safe_review_secret@localhost:5432/handleplan
# Use one bare, unquoted canonical audience tag. It MUST differ from
# OPERATIONS_ACCESS_AUDIENCE even when both private apps share one HTTPS origin.
REVIEW_ACCESS_AUDIENCE=
REVIEW_ACCESS_ISSUER=https://replace-me.cloudflareaccess.com
REVIEW_ACCESS_TEAM_DOMAIN=https://replace-me.cloudflareaccess.com
REVIEW_BASE_URL=https://handle.reidar.tech
# Distinct review-only canonical base64url secret (32-128 random bytes).
REVIEW_EVIDENCE_PROOF_SECRET=
REVIEW_PRIVATE_CAPTURE_ROOT=/var/lib/handleplan/private-captures
# Standalone/local operations runtime only. Production Compose derives this URL
# from OPERATIONS_DATABASE_PASSWORD and does not inject it into app/review.
OPERATIONS_DATABASE_URL=postgresql://handleplan_operations:replace_with_distinct_url_safe_operations_secret@localhost:5432/handleplan
# Use one bare, unquoted canonical audience tag distinct from review.
OPERATIONS_ACCESS_AUDIENCE=
OPERATIONS_ACCESS_ISSUER=https://replace-me.cloudflareaccess.com
OPERATIONS_ACCESS_TEAM_DOMAIN=https://replace-me.cloudflareaccess.com
OPERATIONS_BASE_URL=https://handle.reidar.tech
# Exact compact JSON matching OperationsSourceRosterV1, including its canonical SHA-256.
OPERATIONS_SOURCE_ROSTER_JSON=
# The runtime rejects any value other than false until scheduler/readiness composition exists.
OPERATIONS_ALERT_EVALUATION_ENABLED=false
OFFICIAL_OFFER_FOUNDATION_ENABLED=false
OFFICIAL_OFFER_PRIVATE_CAPTURE_ROOT=/var/lib/handleplan/private-captures
WORKER_CYCLE_INTERVAL_MS=30000
WORKER_LEASE_TTL_MS=120000
WORKER_REQUEST_BUDGET_LIMIT=60
WORKER_REQUEST_BUDGET_MAX_WAIT_MS=65000
WORKER_REQUEST_BUDGET_WINDOW_MS=60000
WORKER_SHUTDOWN_GRACE_MS=30000
WORKER_TARGET_LIMIT=500
