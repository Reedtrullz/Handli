# Inert names-only example. Copy only after the runbook's external gates pass.
HANDLEPLAN_BACKUP_ENABLED=false
HANDLEPLAN_BACKUP_WORK_DIR=/var/lib/handleplan-backup/work
HANDLEPLAN_BACKUP_EVIDENCE_DIR=/var/lib/handleplan-backup/evidence
HANDLEPLAN_BACKUP_CAPTURE_ROOT=/var/lib/handleplan-backup/private-captures
HANDLEPLAN_BACKUP_EXPECTED_CAPTURE_OWNER_UID=10000
HANDLEPLAN_BACKUP_COMMAND_TIMEOUT_MS=7200000
HANDLEPLAN_BACKUP_MAX_ARTIFACT_BYTES=17179869184
HANDLEPLAN_BACKUP_MAX_CAPTURE_ARTIFACT_BYTES=17179869184
HANDLEPLAN_BACKUP_MAX_CAPTURE_FILES=100000
HANDLEPLAN_BACKUP_MAX_CAPTURE_LEDGER_BYTES=67108864
HANDLEPLAN_BACKUP_MAX_CAPTURE_PLAINTEXT_BYTES=17179869184
HANDLEPLAN_BACKUP_DATASET_ID=handleplan-database
HANDLEPLAN_BACKUP_PGSERVICE=handleplan_backup
HANDLEPLAN_BACKUP_PGSERVICE_FILE=/etc/handleplan/backup.pg_service.conf
HANDLEPLAN_BACKUP_PGPASS_FILE=/etc/handleplan/backup.pgpass
HANDLEPLAN_BACKUP_EXPECTED_DATABASE=handleplan
HANDLEPLAN_BACKUP_EXPECTED_ROLE=handleplan_backup
HANDLEPLAN_BACKUP_EXPECTED_SERVER_ID_SHA256=replace_with_64_lowercase_hex
HANDLEPLAN_BACKUP_MIGRATIONS_DIR=/opt/apps/handleplan/operations/current/deploy/migrations
HANDLEPLAN_BACKUP_PGDUMP_BIN=/usr/bin/pg_dump
HANDLEPLAN_BACKUP_PGRESTORE_BIN=/usr/bin/pg_restore
HANDLEPLAN_BACKUP_PSQL_BIN=/usr/bin/psql
HANDLEPLAN_BACKUP_AGE_BIN=/usr/bin/age
HANDLEPLAN_BACKUP_AGE_RECIPIENTS_FILE=/etc/handleplan/backup.age-recipients
HANDLEPLAN_BACKUP_UPLOAD_ADAPTER=/usr/local/libexec/handleplan-backup-upload
HANDLEPLAN_BACKUP_RETENTION_DAYS=35
