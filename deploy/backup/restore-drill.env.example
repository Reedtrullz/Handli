# Inert JIT names-only example. Never store a real age identity in the repo.
HANDLEPLAN_RESTORE_DRILL_ENABLED=false
HANDLEPLAN_RESTORE_ISOLATION_ACK=isolated-disposable-nonproduction-database
HANDLEPLAN_RESTORE_CLUSTER_ACK=server-identity-reviewed-nonproduction
HANDLEPLAN_RESTORE_TEMPLATE_ACK=created-from-template0-for-this-drill
HANDLEPLAN_RESTORE_WORK_DIR=/var/lib/handleplan-restore/work
HANDLEPLAN_RESTORE_EVIDENCE_DIR=/var/lib/handleplan-restore/evidence
HANDLEPLAN_RESTORE_COMMAND_TIMEOUT_MS=7200000
HANDLEPLAN_RESTORE_MAX_ARTIFACT_BYTES=17179869184
HANDLEPLAN_RESTORE_MAX_CAPTURE_ARTIFACT_BYTES=17179869184
HANDLEPLAN_RESTORE_MAX_CAPTURE_FILES=100000
HANDLEPLAN_RESTORE_MAX_CAPTURE_PLAINTEXT_BYTES=17179869184
HANDLEPLAN_RESTORE_EXPECTED_BACKUP_ID=replace_with_backup_id
HANDLEPLAN_RESTORE_EXPECTED_OBJECT_KEY=replace_with_database_object_key
HANDLEPLAN_RESTORE_EXPECTED_CIPHERTEXT_SHA256=replace_with_64_lowercase_hex
HANDLEPLAN_RESTORE_EXPECTED_CAPTURE_OBJECT_KEY=replace_with_capture_object_key
HANDLEPLAN_RESTORE_EXPECTED_CAPTURE_CIPHERTEXT_SHA256=replace_with_64_lowercase_hex
HANDLEPLAN_RESTORE_EXPECTED_MANIFEST_SHA256=replace_with_64_lowercase_hex
HANDLEPLAN_RESTORE_EXPECTED_DATABASE=handleplan_restore_drill_replace_me
HANDLEPLAN_RESTORE_EXPECTED_ROLE=handleplan_restore_drill_replace_me
HANDLEPLAN_RESTORE_EXPECTED_SERVER_ID_SHA256=replace_with_64_lowercase_hex
HANDLEPLAN_RESTORE_PGSERVICE=handleplan_restore_drill_replace_me
HANDLEPLAN_RESTORE_PGSERVICE_FILE=/run/handleplan-restore/restore.pg_service.conf
HANDLEPLAN_RESTORE_PGPASS_FILE=/run/handleplan-restore/restore.pgpass
HANDLEPLAN_RESTORE_ENCRYPTED_FILE=/run/handleplan-restore/database.dump.age
HANDLEPLAN_RESTORE_MANIFEST_FILE=/run/handleplan-restore/manifest.json
HANDLEPLAN_RESTORE_AGE_IDENTITY_FILE=/run/handleplan-restore/age-identity.txt
HANDLEPLAN_RESTORE_DOWNLOAD_ADAPTER=/usr/local/libexec/handleplan-restore-download
HANDLEPLAN_RESTORE_AGE_BIN=/usr/bin/age
HANDLEPLAN_RESTORE_PGRESTORE_BIN=/usr/bin/pg_restore
HANDLEPLAN_RESTORE_PSQL_BIN=/usr/bin/psql
HANDLEPLAN_RESTORE_MIGRATIONS_DIR=/opt/apps/handleplan/operations/current/deploy/migrations
